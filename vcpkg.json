{
    "name": "uff",
    "version": "0.5.9",
    "port-version": 0,
    "description": "Ultrasound Raw eXchange format",
    "homepage": "https://www.moduleus.com/",
    "license": "LGPL-3.0-or-later",
    "dependencies": [
        {
            "name": "vcpkg-cmake",
            "host": true
        },
        {
            "name": "vcpkg-cmake-config",
            "host": true
        }
    ],
    "features": {
        "hdf5": {
            "description": "Enable read / write of urx files",
            "dependencies": [
                {
                    "name": "hdf5",
                    "default-features": false,
                    "features": [
                        "cpp"
                    ]
                }
            ]
        },
        "tests": {
            "description": "Enable testing",
            "dependencies": [
                "catch2"
            ]
        }
    },
    "overrides": [
        {
            "name": "hdf5",
            "version": "1.8.23"
        }
    ]
}