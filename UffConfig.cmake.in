@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
set(HDF5_DIR "@HDF5_DIR@")
if(NOT "${HDF5_DIR}" STREQUAL "")
  find_dependency(
    HDF5
    NAMES
    hdf5
    COMPONENTS
    CXX
    @SEARCH_TYPE@
    CONFIG
    NO_DEFAULT_PATH
    REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/UffTargets.cmake")

check_required_components(Uff)
